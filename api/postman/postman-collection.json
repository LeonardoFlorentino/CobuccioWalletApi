{
    "info": {
        "name": "Cobuccio Wallet API",
        "description": "Collection for testing the Wallet API endpoints",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Auth",
            "item": [
                {
                    "name": "Register User 1",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"{{user1_name}}\",\n  \"email\": \"{{user1_email}}\",\n  \"password\": \"{{default_password}}\",\n  \"password_confirmation\": \"{{default_password}}\"\n}"
                        },
                        "url": "{{base_url}}/api/auth/register"
                    }
                },
                {
                    "name": "Register User 2",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"{{user2_name}}\",\n  \"email\": \"{{user2_email}}\",\n  \"password\": \"{{default_password}}\",\n  \"password_confirmation\": \"{{default_password}}\"\n}"
                        },
                        "url": "{{base_url}}/api/auth/register"
                    }
                },
                {
                    "name": "Login User 1",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"{{user1_email}}\",\n  \"password\": \"{{default_password}}\"\n}"
                        },
                        "url": "{{base_url}}/api/auth/login"
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test(\u0027Login returns success status\u0027, function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "var jsonData = pm.response.json();",
                                    "",
                                    "if (jsonData \u0026\u0026 jsonData.token) {",
                                    "    pm.environment.set(\u0027access_token\u0027, jsonData.token);",
                                    "}",
                                    "",
                                    "pm.test(\u0027Token was saved in environment\u0027, function () {",
                                    "    pm.expect(pm.environment.get(\u0027access_token\u0027)).to.not.be.empty;",
                                    "});"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Get Me",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{access_token}}",
                                "type": "text"
                            }
                        ],
                        "url": "{{base_url}}/api/auth/me"
                    }
                }
            ]
        },
        {
            "name": "Transactions",
            "item": [
                {
                    "name": "Deposit",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{access_token}}",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"amount\": {{deposit_amount}},\n  \"description\": \"Initial deposit\"\n}"
                        },
                        "url": "{{base_url}}/api/transactions/deposit"
                    }
                },
                {
                    "name": "Transfer",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{access_token}}",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"recipient_id\": {{recipient_id}},\n  \"amount\": {{transfer_amount}},\n  \"description\": \"Payment for services\"\n}"
                        },
                        "url": "{{base_url}}/api/transactions/transfer"
                    }
                },
                {
                    "name": "Get Transactions",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{access_token}}",
                                "type": "text"
                            }
                        ],
                        "url": "{{base_url}}/api/transactions?per_page=10"
                    }
                },
                {
                    "name": "Get Transaction Detail",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{access_token}}",
                                "type": "text"
                            }
                        ],
                        "url": "{{base_url}}/api/transactions/{{transaction_id}}"
                    }
                },
                {
                    "name": "Reverse Transaction",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{access_token}}",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"transaction_id\": {{transaction_id}},\n  \"reason\": \"User requested reversal\"\n}"
                        },
                        "url": "{{base_url}}/api/transactions/reverse"
                    }
                }
            ]
        },
        {
            "name": "User",
            "item": [
                {
                    "name": "Get User",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{access_token}}",
                                "type": "text"
                            }
                        ],
                        "url": "{{base_url}}/api/user"
                    }
                }
            ]
        }
    ]
}
